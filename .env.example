# Django
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1,*.herokuapp.com

# Database
DATABASE_NAME=gaming_challenge
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8081,http://localhost:5173

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@gamingchallenge.uz

# Payment Keys
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
PAYME_MERCHANT_ID=your-payme-merchant-id
CLICK_MERCHANT_ID=your-click-merchant-id
UZUM_API_KEY=your-uzum-api-key

# AI Configuration
OPENAI_API_KEY=your-openai-api-key
CLAUDE_API_KEY=your-claude-api-key
GROQ_API_KEY=your-groq-api-key
AI_MODEL=gpt-3.5-turbo

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your-jwt-secret-key
